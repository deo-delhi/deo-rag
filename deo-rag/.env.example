LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=deo-rag

# Local LLM via Ollama
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b-instruct-q5_k_m
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local embeddings via Ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=mxbai-embed-large

# Ingestion / retrieval tuning
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200
# How many chunks are embedded + inserted per batch. Bigger = fewer round-trips
# to Ollama and Postgres, which is the #1 lever for ingest throughput.
INGEST_EMBED_BATCH_SIZE=4
# How many PDFs are processed in parallel (0 = autodetect, 1 = serial).
# When CUDA is usable, the backend caps automatically (1 for HuggingFace
# embeddings on GPU, 2 otherwise) to avoid GPU contention.
INGEST_MAX_WORKERS=1
# HuggingFace embedding micro-batch (0 = backend default: larger on CUDA/XPU).
# Increase on big GPUs if ingest is stable; decrease if you see CUDA OOM.
INGEST_HF_ENCODE_BATCH_SIZE=0
RETRIEVER_TOP_K=20

# Model tuning
LLM_TEMPERATURE=0.1
OLLAMA_NUM_CTX=12288
OLLAMA_NUM_PREDICT=3072
OLLAMA_REQUEST_TIMEOUT_SECONDS=600
# How long Ollama keeps a model resident in VRAM between requests.
# Use "24h" or "-1" to avoid model reload stalls during long ingestions.
OLLAMA_KEEP_ALIVE=24h
ASK_TIMEOUT_SECONDS=600

# Optional if you switch providers to OpenAI
OPENAI_API_KEY=

DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5202/deorag
COLLECTION_NAME=deo_docs
DOCUMENTS_DIR=../documents

# CORS: which frontend origins are allowed to talk to the backend.
# At each DEO office set this to the frontend's actual hostname/IP.
# Example: ALLOWED_ORIGINS=http://localhost:5201,http://127.0.0.1:5201,http://10.20.30.40:5201
# Leave empty to use the safe localhost defaults.
ALLOWED_ORIGINS=
# Optional regex if the office uses a dynamic LAN range. Example for a /16 LAN:
# ALLOWED_ORIGIN_REGEX=^http://192\.168\.\d+\.\d+:5201$
ALLOWED_ORIGIN_REGEX=
