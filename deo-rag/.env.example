LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=deo-rag

# Local LLM via Ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:latest
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local embeddings via HuggingFace
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en

# Ingestion / retrieval tuning
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=120
RETRIEVER_TOP_K=1

# Model tuning
LLM_TEMPERATURE=0
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=128
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
ASK_TIMEOUT_SECONDS=180

# Optional if you switch providers to OpenAI
OPENAI_API_KEY=

DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5202/deorag
COLLECTION_NAME=deo_docs
DOCUMENTS_DIR=../documents

# CORS: which frontend origins are allowed to talk to the backend.
# At each DEO office set this to the frontend's actual hostname/IP.
# Example: ALLOWED_ORIGINS=http://localhost:5201,http://127.0.0.1:5201,http://10.20.30.40:5201
# Leave empty to use the safe localhost defaults.
ALLOWED_ORIGINS=
# Optional regex if the office uses a dynamic LAN range. Example for a /16 LAN:
# ALLOWED_ORIGIN_REGEX=^http://192\.168\.\d+\.\d+:5201$
ALLOWED_ORIGIN_REGEX=
